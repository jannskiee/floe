# Required: Signaling server URL
# Defaults to a local server for development and self-hosting.
# floe.one's own deploy points this at https://api.floe.one instead.
# Reminder: NEXT_PUBLIC_* vars are baked in at build time, so rebuild the
# client after changing this.
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Optional: Public base URL for canonical links, Open Graph tags, and sitemap.
# Set this to your own domain when self-hosting so share previews and SEO point
# at your instance instead of floe.one.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Sentry error tracking (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional: Umami analytics (leave empty to disable)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
